{
  "name": "doubledone-ai",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  // Custom domain: the public surfaces (AI backend, MCP at /mcp, REST API at /api/v1,
  // the Stripe webhook) live at api.doubledone.app, not the account's workers.dev
  // subdomain. Provisioned on `wrangler deploy`. The workers.dev URL stays live too,
  // so the cutover is non-breaking.
  "routes": [{ "pattern": "api.doubledone.app", "custom_domain": true }],
  // workers.dev is retired now that web, native (the EAS env), the docs, and the code
  // defaults all point at the custom domain: false stops the name-bearing
  // doubledone-ai.melroy-a02.workers.dev from resolving, leaving only api.doubledone.app.
  // It was kept true through the cutover so the old URL served until everything moved off.
  "workers_dev": false,
  // Daily web-push nudge (Phase 2): an hourly cron fires the scheduled() handler, which
  // sends to each subscription whose LOCAL hour matches now (see server/src/push.ts).
  "triggers": { "crons": ["0 * * * *"] },
  // Per-IP rate limit on the paid AI routes: 30 requests per 60s. Generous for a
  // real user, a hard cap on scripted abuse against the $25/mo Anthropic budget.
  "ratelimits": [{ "name": "AI_LIMITER", "namespace_id": "1001", "simple": { "limit": 30, "period": 60 } }],
  // Workers AI, for the scrapbook image pipeline (free-tier neurons, no Anthropic call).
  "ai": { "binding": "AI" },
  // R2 bucket for scrapbook keepsake images (off the localStorage quota; the Worker
  // serves them at GET /scrapbook-img/:key).
  "r2_buckets": [{ "binding": "SCRAPBOOKS", "bucket_name": "doubledone-scrapbooks" }],
  // Telemetry store (the moat). D1 is Worker-bound, so there is NO public write
  // path, unlike the old anon-key Supabase insert that anyone could reach.
  "d1_databases": [
    { "binding": "DB", "database_name": "doubledone-telemetry", "database_id": "a5d8ba94-3f1b-46fe-b113-59c7f047aea6" }
  ],
  // In-app feedback: Cloudflare Email Routing's send_email binding lets the Worker email
  // the support inbox. Unrestricted (sends to any verified destination); the recipient is
  // the FEEDBACK_TO secret (the verified support address), set with
  // `npx wrangler secret put FEEDBACK_TO`, never committed.
  "send_email": [{ "name": "SEND_EMAIL" }],
  // Stripe (LIVE) for Premium. Non-secret config: the live recurring price id, safe to commit. The
  // live secret key + webhook signing secret are Worker secrets (set in the Cloudflare dashboard, or
  // via npx wrangler secret put STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET), never committed.
  "vars": {
    "STRIPE_PRICE_ID": "price_1TkHS3JmzIqjJFzqnTgI99Rt",
    "STRIPE_PRICE_ID_ANNUAL": "price_1Tmod5JmzIqjJFzqVa1VRRM6",
    "APP_URL": "https://doubledone.app",
    // The hard Anthropic monthly cap in dollars, the control centre's spend alarm baseline
    // (see server/src/monitor.ts). Non-secret. The dead-man's-switch ping URL is the
    // optional HEARTBEAT_URL Worker secret (npx wrangler secret put HEARTBEAT_URL).
    "ANTHROPIC_MONTHLY_CAP_USD": "25"
  }
}
