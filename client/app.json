{
  "expo": {
    "name": "DoubleDone",
    "slug": "doubledone",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "doubledone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "app.doubledone",
      "adaptiveIcon": {
        "backgroundColor": "#F6F2E9",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F2E9",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-localization",
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false
        }
      ],
      "expo-quick-actions",
      "expo-share-intent",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Today",
              "label": "DoubleDone: Today",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "description": "Today's tasks, at a glance",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/newsreader/600SemiBold/Newsreader_600SemiBold.ttf",
            "node_modules/@expo-google-fonts/atkinson-hyperlegible/400Regular/AtkinsonHyperlegible_400Regular.ttf",
            "node_modules/@expo-google-fonts/atkinson-hyperlegible/700Bold/AtkinsonHyperlegible_700Bold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5add5d3c-fd9a-4ef1-9f60-591ade585d8e"
      }
    },
    "owner": "melroyds"
  }
}
