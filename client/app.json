{
  "expo": {
    "name": "DoubleDone",
    "slug": "doubledone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "doubledone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "app.doubledone",
      "adaptiveIcon": {
        "backgroundColor": "#F6F2E9",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F2E9",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-localization",
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false
        }
      ],
      "expo-quick-actions",
      "expo-share-intent",
      [
        "expo-camera",
        {
          "cameraPermission": "DoubleDone uses the camera to read a to-do list from a photo.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DoubleDone reads a to-do list from a photo you choose."
        }
      ],
      "./plugins/with-exact-alarm",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              { "fontFamily": "Newsreader_600SemiBold", "fontDefinitions": [{ "path": "./assets/fonts/Newsreader_600SemiBold.ttf", "weight": 400 }, { "path": "./assets/fonts/Newsreader_600SemiBold.ttf", "weight": 700 }] },
              { "fontFamily": "AtkinsonHyperlegible_400Regular", "fontDefinitions": [{ "path": "./assets/fonts/AtkinsonHyperlegible_400Regular.ttf", "weight": 400 }, { "path": "./assets/fonts/AtkinsonHyperlegible_400Regular.ttf", "weight": 700 }] },
              { "fontFamily": "AtkinsonHyperlegible_700Bold", "fontDefinitions": [{ "path": "./assets/fonts/AtkinsonHyperlegible_700Bold.ttf", "weight": 400 }, { "path": "./assets/fonts/AtkinsonHyperlegible_700Bold.ttf", "weight": 700 }] }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5add5d3c-fd9a-4ef1-9f60-591ade585d8e"
      }
    },
    "owner": "melroyds"
  }
}
