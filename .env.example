# Copy to .env and fill in real values locally. `.env` is gitignored, NEVER commit it.
# In code, read these via process.env / import.meta.env, never paste literals.
# The Inspector blocks real-looking keys, so keep placeholders here.

# --- Client (Expo) ---------------------------------------------------------
# EXPO_PUBLIC_* is bundled INTO the app, safe to expose, never put secrets here.
EXPO_PUBLIC_APP_NAME=DoubleDone
EXPO_PUBLIC_AI_URL=https://doubledone-ai.melroy-a02.workers.dev   # the AI backend Worker

# --- Server (AI backend = Cloudflare Worker "doubledone-ai") ---------------
# The Anthropic key is a Cloudflare Worker secret, not an env file, and never in
# the client. Set it with:
#   wrangler secret put ANTHROPIC_API_KEY --name doubledone-ai
# Claude is called only from this Worker.
ANTHROPIC_API_KEY=<set-as-a-cloudflare-worker-secret>
LOG_LEVEL=info

# --- Supabase (cloud sync) -------------------------------------------------
# The publishable/anon key is safe to expose in the client bundle. The
# service_role key is NOT, and must never appear in client env or code.
# With these unset the app stays local-only (sync is simply not offered).
# For the deployed web build, set both in the Cloudflare Pages project env too.
EXPO_PUBLIC_SUPABASE_URL=<your-project-url>
EXPO_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>
