# Dependencies
node_modules/

# Build output
dist/
build/
web-build/
*.tsbuildinfo

# Expo
.expo/
expo-env.d.ts

# Environment / secrets, never commit real values
.env
.env.*
!.env.example

# Test / tooling artifacts
coverage/
.vitest/
.eslintcache

# Local virtual environments (if you add a Python service)
.venv/
venv/
__pycache__/

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# Design-handoff mockup HTML, kept local (~3MB, base64-laden, trips the secret scan).
# The README + screenshots in this dir ARE committed as the build reference.
docs/design/redesign/*.html

# Local AI working doc, kept out of the public repo
CLAUDE.md

# Local "what's left" working list, kept out of the public repo
WHATS-LEFT.md

# Bug screenshots + recordings from Android testing, dropped here from the phone via OneDrive.
# Kept out of git: they can hold real task text and would bloat history. OneDrive backs them up.
bugs/
